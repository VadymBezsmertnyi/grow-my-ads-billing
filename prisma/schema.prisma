generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

model Plan {
  id         String   @id @default(cuid())
  name       String   @unique
  feeRate    Float
  minimumFee Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  clients    Client[]
}

model Client {
  id              String   @id @default(cuid())
  name            String
  email           String?
  discountPercent Float    @default(0)
  isActive        Boolean  @default(true)
  planId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  plan            Plan     @relation(fields: [planId], references: [id])
  invoices        Invoice[]
}

model Invoice {
  id                    String        @id @default(cuid())
  clientId              String
  billingMonth          DateTime
  adSpend               Float
  feeRateSnapshot       Float
  minimumFeeSnapshot    Float
  discountSnapshot      Float
  calculatedFee         Float
  finalFee              Float
  status                InvoiceStatus @default(DRAFT)
  stripePaymentIntentId String?
  sentAt                DateTime?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  client                Client        @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([billingMonth])
}